# Copy this file to .env and fill in your values

# Comma-separated frontend origins allowed to call the API from browsers.
# Leave empty to disable CORS middleware.
# Example: CORS_ALLOWED_ORIGINS=https://sayu.example.com,https://www.sayu.example.com
CORS_ALLOWED_ORIGINS=

# Optional: OpenAI API key (for future AI chat features)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Example for other future services
# GEOCODING_API_KEY=your-key-if-needed

# Note: This API currently works without any API keys.
# Geocoding uses the free Nominatim service (no key required).
